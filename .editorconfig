root = true

[*.{java,xml}]
indent_style = tab
indent_size = 4
continuation_indent_size = 8
tab_width = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.{yml,yaml,md,json,properties}]
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
